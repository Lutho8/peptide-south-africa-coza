# Vite environment variables (client-exposed must be prefixed with VITE_)
# Copy to .env.local for local dev, or set in Project Settings → Environment Variables.

# ── Supabase (REQUIRED for auth & cloud sync) ────────────────────────────────
# URL of your Supabase project, e.g. https://<project-id>.supabase.co
VITE_SUPABASE_URL=

# Supabase publishable (anon) key — safe to expose client-side.
VITE_SUPABASE_PUBLISHABLE_KEY=

# ── RevenueCat (optional, for in-app purchases) ──────────────────────────────
# RevenueCat public SDK key for Android (starts with goog_).
# Safe to expose client-side — this is RC's "public" key.
VITE_REVENUECAT_ANDROID_KEY=

# (Optional, for future iOS build) RevenueCat iOS public SDK key (appl_…)
VITE_REVENUECAT_IOS_KEY=
